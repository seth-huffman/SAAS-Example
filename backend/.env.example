# Example backend environment variables
# Copy this to .env and replace placeholders with real values.
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5174

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=hruser
DB_PASSWORD=hrpassword
DB_DATABASE=hrdb

# Seed admin
SEED_ADMIN_EMAIL=seth@shiftcontrol.io
SEED_ADMIN_PASSWORD=Admin123!

# LinkedIn OAuth (replace with your app credentials)
LINKEDIN_CLIENT_ID=REPLACE_WITH_CLIENT_ID
LINKEDIN_CLIENT_SECRET=REPLACE_WITH_CLIENT_SECRET
# The redirect URI must match the one configured in your LinkedIn app
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/callback
